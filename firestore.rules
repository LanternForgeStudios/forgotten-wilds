rules_version = '2';

// Anti-cheat boundary: the cloud is the source of truth, not the browser.
//
// `users/{uid}` and `combatSessions/{uid}` hold authoritative save/combat state and are
// NEVER writable directly from the client — every mutation goes through a Cloud Function
// (Admin SDK, which bypasses these rules entirely). The client can only read its own data.
//
// `presence/{uid}` is the one collection clients write directly, because the worst case of
// tampering there is a fake nameplate, not an economy/progression exploit, and real-time
// responsiveness matters more than server validation for town presence.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /combatSessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['displayName', 'avatarSymbol', 'locationId', 'lastHeartbeat', 'joinedAt', 'x', 'y'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.avatarSymbol is string
        && request.resource.data.locationId is string
        && request.resource.data.lastHeartbeat is number
        && request.resource.data.joinedAt is number
        && request.resource.data.x is number
        && request.resource.data.y is number;
    }

    // Social: friend search/requests/blocking/DMs. All server-authoritative, same anti-cheat
    // reasoning as users/combatSessions above - clients only ever read these, every write goes
    // through a Cloud Function (searchUsers, friends.ts, blocking.ts, sendDirectMessage.ts).

    match /userDirectory/{uid} {
      // Public read (any signed-in player can search by name) - the entry itself never contains
      // email or anything sensitive, only uid/displayName.
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow write: if false;
    }

    match /friendships/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /blocks/{uid} {
      // Never readable by anyone but the owner - a blocked user is never told they've been blocked.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /directMessages/{messageId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow write: if false;
    }

    // Trading: friends-only item/gold trades (trade.ts), also server-authoritative.

    match /trades/{tradeId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow write: if false;
    }

    match /activeTradeLocks/{pairKey} {
      // Internal bookkeeping only (see trade.ts's sortedPairKey) - nothing in the UI ever needs
      // to read this, so it's not even readable by its own participants.
      allow read: if false;
      allow write: if false;
    }
  }
}
